# ------------------------------------------------------------------
# DTU Nexus — environment variables
# Copy this file to `.env.local` and fill in the values.
# ------------------------------------------------------------------

# MongoDB connection string.
# Local:  mongodb://localhost:27017/dtu-nexus
# Prod:   MongoDB Atlas SRV string (mongodb+srv://user:pass@cluster.xxxx.mongodb.net/dtu-nexus)
MONGODB_URI=

# NextAuth secret — generate with:  openssl rand -base64 32
AUTH_SECRET=

# The public base URL of the app.
# Local:  http://localhost:3000
# Prod:   https://<your-app>.vercel.app
NEXTAUTH_URL=

# ---- Google OAuth (OPTIONAL) --------------------------------------
# Only needed if you want real Google sign-in. The one-click Demo Login
# works without these. Get them from Google Cloud Console and add the
# redirect URI:  <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
